{
  "schemaVersion": 1,
  "slug": "vibe-mybooks",
  "displayName": "Vibe MyBooks",
  "description": "Bookkeeping and ledger management for small accounting practices.",
  "logo": "vibe-mybooks.svg",

  "image": {
    "server":     "ghcr.io/kisaesdevlab/vibe-mybooks-server",
    "client":     "ghcr.io/kisaesdevlab/vibe-mybooks-client",
    "defaultTag": "latest"
  },

  "subdomain": "mybooks",
  "ports":     { "server": 3001, "client": 80 },

  "routing": {
    "default_upstream": "vibe-mybooks-client:80",
    "matchers": [
      { "name": "api", "path": "/api/*", "upstream": "vibe-mybooks-server:3001" }
    ]
  },

  "depends": ["postgres", "redis"],

  "env": {
    "required": [
      { "name": "JWT_SECRET",      "from": "shared:JWT_SECRET" },
      { "name": "ENCRYPTION_KEY",  "from": "shared:ENCRYPTION_KEY" },
      { "name": "ALLOWED_ORIGIN",  "from": "subdomain-url" },
      { "name": "DATABASE_URL",    "from": "database-url" },
      { "name": "REDIS_URL",       "from": "redis-url" },
      { "name": "MIGRATIONS_AUTO", "from": "static:false" }
    ]
  },

  "database": { "name": "vibe_mybooks_db", "user": "vibemybooks" },
  "redis":    { "db": 1 },

  "firstLogin": {
    "type":     "default-credentials-forced-reset",
    "username": "admin",
    "password": "admin",
    "url":      "/login"
  },

  "health": "/api/v1/health",

  "migrations": {
    "command":    ["node", "dist/migrate.js"],
    "autoEnvVar": "MIGRATIONS_AUTO"
  }
}
