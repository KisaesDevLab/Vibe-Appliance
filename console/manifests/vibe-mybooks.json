{
  "schemaVersion": 1,
  "slug": "vibe-mybooks",
  "displayName": "Vibe MyBooks",
  "description": "Bookkeeping and ledger management for small accounting practices.",
  "logo": "vibe-mybooks.svg",

  "image": {
    "server":     "ghcr.io/kisaesdevlab/vibe-mybooks-api",
    "client":     "ghcr.io/kisaesdevlab/vibe-mybooks-web",
    "defaultTag": "latest"
  },

  "subdomain":     "mybooks",
  "emergencyPort": 5171,
  "ports":         { "server": 3001, "client": 5173 },

  "routing": {
    "default_upstream": "vibe-mybooks-web:5173",
    "matchers": [
      { "name": "api", "path": "/api/*", "upstream": "vibe-mybooks-api:3001" }
    ]
  },

  "depends": ["postgres", "redis"],

  "env": {
    "required": [
      { "name": "JWT_SECRET",      "from": "shared:JWT_SECRET" },
      { "name": "ENCRYPTION_KEY",  "from": "shared:ENCRYPTION_KEY" },
      { "name": "ALLOWED_ORIGIN",  "from": "subdomain-url" },
      { "name": "DATABASE_URL",    "from": "database-url" },
      { "name": "REDIS_URL",       "from": "redis-url" },
      { "name": "MIGRATIONS_AUTO", "from": "static:false" }
    ],
    "optional": [
      {
        "name":   "ANTHROPIC_API_KEY",
        "from":   "appliance:ANTHROPIC_API_KEY",
        "secret": true,
        "doc":    "Claude API key for AI-assisted bookkeeping. Inherited from appliance-wide ANTHROPIC_API_KEY (Settings → AI) unless overridden for this app.",
        "ui": {
          "tier":         1,
          "category":     "AI",
          "label":        "Anthropic API key",
          "helpText":     "Powers Vibe-MyBooks AI features. The same key is used appliance-wide unless overridden per-app.",
          "input":        "password",
          "appliance":    "both",
          "validate":     "anthropic-api-key",
          "testEndpoint": "/api/v1/admin/test/anthropic"
        }
      },
      {
        "name":  "LICENSE_MODE",
        "value": "online",
        "doc":   "License validation mode. 'online' phones home periodically, 'offline' uses a pre-issued license file, 'disabled' bypasses license checks.",
        "ui": {
          "tier":      1,
          "category":  "Application",
          "label":     "License mode",
          "helpText":  "Controls how MyBooks validates its license. 'offline' for air-gapped installs.",
          "input":     "dropdown",
          "appliance": "per-app",
          "validate":  "enum",
          "options": [
            { "value": "online",   "label": "Online (default)" },
            { "value": "offline",  "label": "Offline (pre-issued license file)" },
            { "value": "disabled", "label": "Disabled (no license check)" }
          ]
        }
      },
      {
        "name":  "LOG_LEVEL",
        "value": "info",
        "doc":   "Application log verbosity. Use 'debug' only when investigating an issue — high volume in production.",
        "ui": {
          "tier":      1,
          "category":  "Time & Logging",
          "label":     "Log level",
          "input":     "dropdown",
          "appliance": "per-app",
          "validate":  "enum",
          "options": [
            { "value": "error", "label": "error" },
            { "value": "warn",  "label": "warn"  },
            { "value": "info",  "label": "info"  },
            { "value": "debug", "label": "debug" }
          ]
        }
      }
    ]
  },

  "database": { "name": "vibe_mybooks_db", "user": "vibemybooks" },
  "redis":    { "db": 1 },

  "firstLogin": {
    "type":     "default-credentials-forced-reset",
    "username": "admin",
    "password": "admin",
    "url":      "/login"
  },

  "health": "/health",

  "migrations": {
    "command":    ["node", "dist/migrate.js"],
    "autoEnvVar": "MIGRATIONS_AUTO"
  }
}
