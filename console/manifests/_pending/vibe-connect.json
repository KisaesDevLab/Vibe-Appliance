{
  "schemaVersion": 1,
  "slug": "vibe-connect",
  "displayName": "Vibe Connect",
  "description": "Secure document and message exchange between firm and clients.",
  "logo": "vibe-connect.svg",

  "image": {
    "server":     "ghcr.io/kisaesdevlab/vibe-connect-server",
    "client":     "ghcr.io/kisaesdevlab/vibe-connect-client",
    "defaultTag": "latest"
  },

  "subdomain": "connect",
  "ports":     { "server": 4000, "client": 80 },

  "routing": {
    "default_upstream": "vibe-connect-client:80",
    "matchers": [
      { "name": "websocket", "path": "/socket.io/*", "upstream": "vibe-connect-client:80", "streaming": true }
    ]
  },

  "depends": ["postgres"],

  "env": {
    "required": [
      { "name": "DATABASE_URL",   "from": "database-url" },
      { "name": "SESSION_SECRET", "from": "shared:JWT_SECRET" }
    ],
    "optional": [
      { "name": "OIDC_ISSUER_URL",
        "doc": "OIDC issuer URL for SSO. Set via 'sudo nano /opt/vibe/env/vibe-connect.env'." },
      { "name": "POSTMARK_INBOUND_WEBHOOK_SECRET", "secret": true,
        "doc": "Inbound email webhook signing secret (Postmark)." },
      { "name": "POSTFIX_RAW_BRIDGE_SECRET", "secret": true,
        "doc": "Raw email bridge secret (self-hosted Postfix)." },
      { "name": "CLAMD_HOST",
        "doc": "ClamAV host for attachment scanning. Omit to skip scanning." },
      { "name": "CLAMD_PORT",
        "doc": "ClamAV port. Default 3310." }
    ]
  },

  "database": { "name": "vibe_connect_db", "user": "vibeconnect" },

  "firstLogin": {
    "type": "none",
    "url":  "/install"
  },

  "health": "/health"
}
