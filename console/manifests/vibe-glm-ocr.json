{
  "schemaVersion": 1,
  "slug": "vibe-glm-ocr",
  "displayName": "Vibe GLM-OCR",
  "description": "Document OCR powered by an on-host vision-language model. Single image, self-contained.",
  "logo": "vibe-glm-ocr.svg",

  "image": {
    "server":     "ghcr.io/kisaesdevlab/vibe-glm-ocr",
    "defaultTag": "latest"
  },

  "subdomain":  "ocr",
  "userFacing": false,
  "ports":      { "server": 8090 },

  "routing": {
    "default_upstream": "vibe-glm-ocr:8090",
    "matchers": [
      { "name": "stream", "path": "/api/ocr/stream*", "upstream": "vibe-glm-ocr:8090", "streaming": true }
    ]
  },

  "depends": ["redis"],

  "env": {
    "required": [
      { "name": "JWT_SECRET",      "from": "shared:JWT_SECRET" },
      { "name": "ALLOWED_ORIGIN",  "from": "subdomain-url" },
      { "name": "REDIS_URL",       "from": "redis-url" }
    ]
  },

  "redis": { "db": 5 },

  "firstLogin": {
    "type":     "default-credentials-passive",
    "username": "admin",
    "password": "admin",
    "url":      "/"
  },

  "health": "/health",
  "health_timeout_s": 300
}
