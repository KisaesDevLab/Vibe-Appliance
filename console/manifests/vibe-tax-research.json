{
  "schemaVersion": 1,
  "slug": "vibe-tax-research",
  "displayName": "Vibe Tax Research Chat",
  "description": "Chat-based research assistant over the IRC, court rulings, and firm-internal memos.",
  "logo": "vibe-tax-research.svg",

  "image": {
    "server":     "ghcr.io/kisaesdevlab/vibe-tax-api",
    "client":     "ghcr.io/kisaesdevlab/vibe-tax-web",
    "defaultTag": "latest"
  },

  "subdomain":     "tax-research",
  "emergencyPort": 5191,
  "ports":         { "server": 4000, "client": 80 },

  "routing": {
    "default_upstream": "vibe-tax-research-web:80",
    "matchers": [
      { "name": "api",  "path": "/api/*",  "upstream": "vibe-tax-research-api:4000" },
      { "name": "chat", "path": "/chat/*", "upstream": "vibe-tax-research-api:4000", "streaming": true }
    ]
  },

  "depends": ["postgres", "redis"],

  "env": {
    "required": [
      { "name": "JWT_SECRET",      "from": "shared:JWT_SECRET" },
      { "name": "ENCRYPTION_KEY",  "from": "shared:ENCRYPTION_KEY" },
      { "name": "ALLOWED_ORIGIN",  "from": "subdomain-url" },
      { "name": "DATABASE_URL",    "from": "database-url" },
      { "name": "REDIS_URL",       "from": "redis-url" },
      { "name": "MIGRATIONS_AUTO", "from": "static:false" }
    ],
    "optional": [
      {
        "name":   "ANTHROPIC_API_KEY",
        "from":   "appliance:ANTHROPIC_API_KEY",
        "secret": true,
        "doc":    "Claude API key powering the chat tier. Inherited from the appliance-wide ANTHROPIC_API_KEY (Settings → AI) unless explicitly overridden for this app.",
        "ui": {
          "tier":         1,
          "category":     "AI",
          "label":        "Anthropic API key",
          "helpText":     "Required for the Tax Research chat tier. Shared with other AI-using Vibe apps unless overridden.",
          "input":        "password",
          "appliance":    "both",
          "validate":     "anthropic-api-key",
          "testEndpoint": "/api/v1/admin/test/anthropic"
        }
      }
    ]
  },

  "database": { "name": "vibe_tax_research_db", "user": "vibetaxresearch" },
  "redis":    { "db": 3 },

  "requiredExtensions": ["vector", "pg_search"],

  "firstLogin": {
    "type": "setup-wizard",
    "note": "First-run wizard at /setup creates the SuperAdmin. The dev-only seed (SEED_ADMIN_EMAIL / SEED_ADMIN_PASSWORD in upstream .env.example) is NOT applied in appliance mode — those env vars are unset.",
    "url":  "/setup"
  },

  "health": "/api/health",

  "migrations": {
    "command":    ["node", "dist/migrate.js"],
    "autoEnvVar": "MIGRATIONS_AUTO"
  }
}
