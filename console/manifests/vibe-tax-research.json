{
  "schemaVersion": 1,
  "slug": "vibe-tax-research",
  "displayName": "Vibe Tax Research Chat",
  "description": "Chat-based research assistant over the IRC, court rulings, and firm-internal memos.",
  "logo": "vibe-tax-research.svg",

  "image": {
    "server":     "ghcr.io/kisaesdevlab/vibe-tax-api",
    "client":     "ghcr.io/kisaesdevlab/vibe-tax-web",
    "defaultTag": "latest"
  },

  "subdomain": "tax-research",
  "ports":     { "server": 4000, "client": 80 },

  "routing": {
    "default_upstream": "vibe-tax-research-web:80",
    "matchers": [
      { "name": "api",  "path": "/api/*",  "upstream": "vibe-tax-research-api:4000" },
      { "name": "chat", "path": "/chat/*", "upstream": "vibe-tax-research-api:4000", "streaming": true }
    ]
  },

  "depends": ["postgres", "redis"],

  "env": {
    "required": [
      { "name": "JWT_SECRET",      "from": "shared:JWT_SECRET" },
      { "name": "ENCRYPTION_KEY",  "from": "shared:ENCRYPTION_KEY" },
      { "name": "ALLOWED_ORIGIN",  "from": "subdomain-url" },
      { "name": "DATABASE_URL",    "from": "database-url" },
      { "name": "REDIS_URL",       "from": "redis-url" },
      { "name": "MIGRATIONS_AUTO", "from": "static:false" }
    ],
    "optional": [
      { "name": "ANTHROPIC_API_KEY", "secret": true,
        "doc":  "Claude API key. Required for the chat tier — set via 'sudo nano /opt/vibe/env/vibe-tax-research.env'." }
    ]
  },

  "database": { "name": "vibe_tax_research_db", "user": "vibetaxresearch" },
  "redis":    { "db": 3 },

  "firstLogin": {
    "type":     "default-credentials-forced-reset",
    "username": "admin",
    "password": "admin",
    "url":      "/login"
  },

  "health": "/api/health",

  "migrations": {
    "command":    ["node", "dist/migrate.js"],
    "autoEnvVar": "MIGRATIONS_AUTO"
  }
}
