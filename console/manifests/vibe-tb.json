{
  "schemaVersion": 1,
  "slug": "vibe-tb",
  "displayName": "Vibe Trial Balance",
  "description": "Tax preparation and trial balance workpaper application.",
  "logo": "vibe-tb.svg",

  "image": {
    "server":     "ghcr.io/kisaesdevlab/vibe-tb-server",
    "client":     "ghcr.io/kisaesdevlab/vibe-tb-client",
    "defaultTag": "latest"
  },

  "subdomain":     "tb",
  "emergencyPort": 5172,
  "ports":         { "server": 3001, "client": 80 },

  "routing": {
    "default_upstream": "vibe-tb-client:80",
    "matchers": [
      { "name": "api", "path": "/api/*", "upstream": "vibe-tb-server:3001" },
      { "name": "mcp", "path": "/mcp/*", "upstream": "vibe-tb-server:3001", "streaming": true }
    ]
  },

  "depends": ["postgres", "redis"],
  "optionalDepends": ["vibe-glm-ocr"],

  "env": {
    "required": [
      { "name": "JWT_SECRET",      "from": "shared:JWT_SECRET" },
      { "name": "ENCRYPTION_KEY",  "from": "shared:ENCRYPTION_KEY" },
      { "name": "ALLOWED_ORIGIN",  "from": "subdomain-url" },
      { "name": "DATABASE_URL",    "from": "database-url" },
      { "name": "REDIS_URL",       "from": "redis-url" },
      { "name": "MIGRATIONS_AUTO", "from": "static:false" }
    ],
    "optional": [
      {
        "name":   "ANTHROPIC_API_KEY",
        "from":   "appliance:ANTHROPIC_API_KEY",
        "secret": true,
        "doc":    "Claude API key for AI features. Set via the admin Settings page (AI category). Inherited from appliance.env unless overridden per-app.",
        "ui": {
          "tier":         1,
          "category":     "AI",
          "label":        "Anthropic API key",
          "helpText":     "Powers Vibe-TB AI features. The same key is used appliance-wide unless overridden per-app.",
          "input":        "password",
          "appliance":    "both",
          "validate":     "anthropic-api-key",
          "testEndpoint": "/api/v1/admin/test/anthropic"
        }
      }
    ]
  },

  "database": { "name": "vibe_tb_db", "user": "vibetb" },
  "redis":    { "db": 0 },

  "firstLogin": {
    "type":     "default-credentials-forced-reset",
    "username": "admin",
    "password": "admin1234",
    "note":     "Source: upstream seed server/seeds/001_default_admin.js. First login forces a password rotation. If 'invalid credentials', the seed didn't run — diagnose with: sudo docker exec vibe-postgres psql -U vibetb -d vibe_tb_db -c 'SELECT username FROM users;'.",
    "url":      "/login"
  },

  "health": "/api/v1/health",

  "migrations": {
    "command":    ["node", "dist/migrate.js"],
    "autoEnvVar": "MIGRATIONS_AUTO"
  }
}
