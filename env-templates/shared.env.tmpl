# shared.env.tmpl — rendered to /opt/vibe/env/shared.env by lib/secrets.sh.
#
# Each {{PLACEHOLDER}} is replaced with a securely-generated hex32 value
# on first bootstrap. On subsequent runs existing values are preserved
# (idempotent); pass --reset-env to bootstrap.sh to rotate.
#
# This file IS the schema. Add a new line, place a {{NAME}} marker on the
# right of the equals sign, and secrets.sh will generate the value next
# run. To add a non-secret default, write the value directly.
#
# Lines without an equals sign and lines starting with '#' are passed
# through unchanged.

# --- Postgres (shared) ---
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PASSWORD={{POSTGRES_PASSWORD}}

# --- Redis (shared) ---
REDIS_PASSWORD={{REDIS_PASSWORD}}

# --- App-shared crypto material ---
# Used by individual apps that opt in via env-templates/per-app/*.env.tmpl.
JWT_SECRET={{JWT_SECRET}}
ENCRYPTION_KEY={{ENCRYPTION_KEY}}

# --- Console admin credentials ---
# The username is fixed; the password is generated and surfaced in
# /opt/vibe/CREDENTIALS.txt. Rotate via: sudo bootstrap.sh --reset-env
CONSOLE_ADMIN_USER=admin
CONSOLE_ADMIN_PASSWORD={{CONSOLE_ADMIN_PASSWORD}}

# --- Duplicati ---
# Two unrelated secrets despite the shared name prefix:
#   DUPLICATI_PASSPHRASE: per-backup AES-256 passphrase the operator
#     types into Duplicati's UI when configuring a backup destination.
#     Surfaced in CREDENTIALS.txt; not consumed by the container.
#   SETTINGS_ENCRYPTION_KEY: encrypts Duplicati's own internal settings
#     database (job configs, schedule). Required since Duplicati 2.1
#     (linuxserver image v2.3+); without it Duplicati refuses to start.
#     Container reads this env var directly. CRITICAL: if lost, the
#     settings DB is unrecoverable on restore — must be in CREDENTIALS.txt.
DUPLICATI_PASSPHRASE={{DUPLICATI_PASSPHRASE}}
SETTINGS_ENCRYPTION_KEY={{SETTINGS_ENCRYPTION_KEY}}

# --- Optional: Cloudflare DNS-01 wildcard certs (advanced) ---
# The default install uses HTTP-01 per-subdomain certs and does NOT need
# a Cloudflare token. Only set CLOUDFLARE_API_TOKEN if you've opted into
# the custom Caddy build at caddy/Dockerfile.cloudflare. See that file's
# header for the full opt-in steps.
# CLOUDFLARE_API_TOKEN=
