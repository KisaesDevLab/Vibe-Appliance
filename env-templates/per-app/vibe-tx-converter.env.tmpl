# vibe-tx-converter.env.tmpl — rendered to /opt/vibe/env/vibe-tx-converter.env
# by lib/enable-app.sh.
#
# The Convertor reads DATABASE_URL + REDIS_URL directly. SESSION_SECRET
# must be at least 32 bytes; we alias the appliance-wide JWT_SECRET
# (already 32 bytes of hex) rather than generating a parallel secret.
#
# LLM provider routing:
#   LLM_PROVIDER=anthropic + ANTHROPIC_API_KEY  → uses Claude (appliance default)
#   LLM_PROVIDER=local     + LLM_GATEWAY_URL    → external local LLM server
# The appliance does not currently ship an in-network LLM gateway, so
# the default below is anthropic. Operators with their own local LLM
# server (Ollama, llama.cpp, vibe-llm-server) can flip this and supply
# the URL.

NODE_ENV=production
PORT=4000

# --- Routing identity -------------------------------------------------
ALLOWED_ORIGIN=@ALLOWED_ORIGIN@
WEB_BASE_URL=@ALLOWED_ORIGIN@

# Vite SPA base-path — must match the Caddy prefix (`/<slug>/` in
# LAN/Tailscale, `/` in domain mode).
VITE_BASE_PATH=@VITE_BASE_PATH@

# --- Sessions ---------------------------------------------------------
SESSION_SECRET=@JWT_SECRET@

# --- Data plane ------------------------------------------------------
DATABASE_URL=@DATABASE_URL@
REDIS_URL=@REDIS_URL@

# --- Storage --------------------------------------------------------
DATA_DIR=/var/lib/vibetc
MAX_UPLOAD_MB=25
MAX_BATCH_SIZE=100

# --- GLM-OCR (cross-app) ---------------------------------------------
# The Convertor calls vibe-glm-ocr over the shared docker network when
# OCR is needed. Address resolves only when vibe-glm-ocr is also
# enabled; otherwise OCR-requiring requests fail with a clear upstream
# error. Enable both apps to use the OCR path.
GLM_OCR_URL=http://vibe-glm-ocr:8090
GLM_OCR_TIMEOUT_MS=60000
GLM_OCR_CONCURRENCY=2
GLM_OCR_CACHE_TTL_DAYS=7

# --- LLM provider ---------------------------------------------------
# Anthropic via the appliance's own key (Settings → AI). Override per-app
# in this file or via the admin Settings page if you've configured a
# local LLM gateway.
LLM_PROVIDER=anthropic
LLM_TIMEOUT_MS=60000
LLM_MAX_PROMPT_TOKENS=24000
LLM_MAX_COMPLETION_TOKENS=6000
LLM_CACHE_TTL_HOURS=24

# --- Worker / appliance ---------------------------------------------
WORKER_INLINE=true
APPLIANCE_MODE=true
APPLIANCE_VERSION=1

# --- Migrations -----------------------------------------------------
# False because enable-app.sh runs the manifest's migrations.command
# explicitly with rollback safety.
MIGRATIONS_AUTO=false

# --- Optional knobs (override via 'sudo nano /opt/vibe/env/vibe-tx-converter.env') ---
# ANTHROPIC_API_KEY=     # inherited from appliance.env
# ANTHROPIC_MODEL=       # inherited from appliance.env
# ANTHROPIC_BASE_URL=https://api.anthropic.com
#
# To switch to a local LLM gateway (Ollama / llama.cpp / vibe-llm-server):
#   LLM_PROVIDER=local
#   LLM_GATEWAY_URL=http://your-llm-host:11434
#   LLM_MODEL_ID=qwen3-8b
