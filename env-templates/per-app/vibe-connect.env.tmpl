# vibe-connect.env.tmpl — rendered to /opt/vibe/env/vibe-connect.env by
# lib/enable-app.sh. Connect server reads these via apps/server/src/env.ts;
# Connect client (nginx) reads BASE_PATH / SESSION_COOKIE_PATH / TLS_MODE
# via infra/docker/nginx/entrypoint.sh.

NODE_ENV=production

# --- Database (single shared DATABASE_URL — Connect uses Knex) --------
DATABASE_URL=@DATABASE_URL@

# --- Session (cookie-based, NOT JWT) ----------------------------------
# Reuse the shared JWT_SECRET as the session signing key — same
# cryptographic strength, one fewer secret the operator has to track.
SESSION_SECRET=@JWT_SECRET@
# SESSION_SECURE marks the cookie with the `Secure` flag, which makes the
# browser only send it over HTTPS. We'd like to compute this from the
# install mode (true in domain/tailscale, false in lan) the way every other
# field on this row does — and we used to. Pinned to `false` for now as a
# workaround for a Vibe-Connect upstream nginx bug: vibe-connect-client's
# nginx.conf.template uses `proxy_set_header X-Forwarded-Proto $scheme`,
# which OVERWRITES Caddy's `X-Forwarded-Proto: https` with the local plain-
# HTTP scheme on the Caddy→nginx hop. The Node server then reads
# `req.secure = false` and express-session silently drops the Set-Cookie
# header for cookies with `secure: true` — every login appears to succeed
# (session row written to PgStore) but the browser never receives the
# cookie, so every subsequent request 401s. Flipping SESSION_SECURE=false
# keeps the cookie alive at the cost of dropping the Secure flag — minimal
# real-world exposure on a Cloudflare-Tunnel deploy (the edge is HTTPS-
# only) but a defense-in-depth weakening. Restore `@SESSION_SECURE@` once
# vibe-connect-client images ship the nginx fix (preserve upstream
# X-Forwarded-Proto via a `map` falling back to $scheme).
SESSION_SECURE=false

# --- Path-prefix routing ----------------------------------------------
# Connect's nginx (vibe-connect-client) entrypoint validates BASE_PATH
# strictly: must be `/` or `/<lowercase>` with optional trailing slash.
# The appliance computes VITE_BASE_PATH from the slug minus the
# redundant `vibe-` prefix: `/connect/` here, `/tb/` for vibe-tb, etc.
# Same shape in LAN, Tailscale, and domain modes.
BASE_PATH=@VITE_BASE_PATH@

# --- Session cookie path + name --------------------------------------
# In Connect's docs SESSION_COOKIE_PATH is supposed to match BASE_PATH,
# but in the appliance that breaks login: Caddy `uri strip_prefix
# /connect` rewrites the URL upstream to `/auth/login`, so by the
# time express-session compares `cookie.path` (`/connect/`) to
# `req.originalUrl` (`/auth/login`), it logs `pathname mismatch` and
# refuses to attach `req.session`. Login then 500s on `req.session.
# regenerate`. Connect's own nginx config (`location ~ ^/(auth|...)`)
# already assumes the prefix is stripped upstream — its design is
# internally inconsistent with the cookie-path-equals-BASE_PATH rule.
#
# Workaround: pin cookie path to `/` (so it matches every request post-
# strip) and give Connect a slug-scoped SESSION_COOKIE_NAME so a sibling
# Vibe app at the same host doesn't clobber its session cookie. The
# secrecy of the cookie is preserved by SESSION_SECRET (signed cookie),
# not by the path scope.
SESSION_COOKIE_PATH=/
SESSION_COOKIE_NAME=vibe-connect.sid

# --- TLS handling -----------------------------------------------------
# Caddy terminates TLS upstream of Connect's nginx. The in-app ACME
# ticker (TLS_MODE=internal) is off; Connect's nginx serves plain HTTP
# on :80 for Caddy to reverse-proxy.
TLS_MODE=external

# --- Operator-supplied (override via 'sudo nano /opt/vibe/env/vibe-connect.env') ---
# OIDC_ISSUER_URL=
# POSTMARK_INBOUND_WEBHOOK_SECRET=
# POSTFIX_RAW_BRIDGE_SECRET=

# --- Phase 28 intake encryption-at-rest key --------------------------
# 32 raw bytes (libsodium secretbox / XChaCha20-Poly1305 key) encoded as
# base64. Encrypts every intake row + uploaded file at rest. Generated
# ONCE on first render and PRESERVED across re-renders — rotating it
# would brick every prior encrypted intake row + file. Treat with the
# same care as the firm recovery phrase. The /opt/vibe/env/vibe-connect.env
# file is mode 600 root-owned and included in the Duplicati backup set.
CONNECT_INTAKE_ENCRYPTION_KEY=@CONNECT_INTAKE_ENCRYPTION_KEY@

# --- Upload AV scanning ---
# Vibe-Connect's env validator refuses to start in production without
# either CLAMD_HOST set OR ALLOW_UNSCANNED_UPLOADS=1 explicitly
# acknowledged. The appliance doesn't ship ClamAV by default (it's
# ~2 GB of RAM, multi-minute signature downloads on first start, and
# adds operational complexity novice CPAs don't want to manage).
#
# Default posture: acknowledge shipping without AV scanning. Uploads
# are typically PDFs and spreadsheets from known clients/staff, so
# the marginal risk is bounded. If you want AV scanning anyway, run a
# clamav/clamav container on vibe_net and set CLAMD_HOST/CLAMD_PORT
# below — the env validator will accept that path too. See
# docs/addenda/emergency-access.md (TODO: add a separate ClamAV
# opt-in addendum) for the recommended compose snippet.
ALLOW_UNSCANNED_UPLOADS=1
# CLAMD_HOST=clamav
# CLAMD_PORT=3310
