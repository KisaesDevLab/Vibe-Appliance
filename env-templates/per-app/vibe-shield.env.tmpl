# vibe-shield.env.tmpl — rendered to /opt/vibe/env/vibe-shield.env
# by lib/enable-app.sh.
#
# Vibe Shield is the appliance's mandatory egress gateway to Anthropic.
# It runs three containers:
#   - vibe-shield-engine    (Python + Presidio + spaCy lg; internal-only)
#   - vibe-shield-gateway   (Anthropic-Messages-compatible API; :8080)
#   - vibe-shield-admin     (React SPA served by nginx; :80)
# plus a one-shot:
#   - vibe-shield-migrate   (profile: bootstrap; runs Drizzle migrate)
#
# Other Vibe apps on this appliance MUST route Anthropic traffic
# through the gateway. They configure their SDK as:
#   ANTHROPIC_BASE_URL=http://vibe-shield-gateway:8080
#   ANTHROPIC_API_KEY=vs_live_...   (issued via admin UI)

NODE_ENV=production

# --- Routing identity -------------------------------------------------
# Same placeholder set every other app uses; render-caddyfile.sh
# substitutes these from the appliance domain + mode at render time.
ALLOWED_ORIGIN=@ALLOWED_ORIGIN@
VITE_BASE_PATH=@VITE_BASE_PATH@

# --- Data plane ------------------------------------------------------
DATABASE_URL=@DATABASE_URL@
REDIS_URL=@REDIS_URL@

# Slot allocation for the shared Redis: 0 tb, 1 mybooks, 2 calculators,
# 3 tax-research, 4 payroll, 6 tx-converter, 7 shield. (5 was glm-ocr
# but the upstream image does not use Redis; the slot is unallocated.)
VIBE_REDIS_DB=7

# --- Engine ↔ Gateway -----------------------------------------------
# Engine is internal-only; gateway reaches it on the vibe_net Docker
# DNS name. NEVER published via Caddy.
ENGINE_URL=http://vibe-shield-engine:8000

# --- Secrets ---------------------------------------------------------
# Three secrets Shield needs are NOT auto-rendered here — they're
# inherited or set manually. The compose overlay's env_file order
# (shared.env, appliance.env, vibe-shield.env) means anything set in
# appliance.env carries into the container unless overridden here.
#
# 1. ANTHROPIC_API_KEY — appliance-wide. Already in appliance.env
#    (set during Phase 6 of bootstrap or via Settings → AI). Shield
#    probes this at boot via GET /v1/models and refuses to start on
#    a consumer-grade key (Free/Pro/Max from claude.ai).
#
# 2. VS_KEK — Shield-specific. AES-256-GCM master key wrapping
#    per-tenant DEKs. Generate ONCE per appliance and add to
#    /opt/vibe/env/appliance.env (so it propagates to Shield via
#    env_file inheritance):
#      node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#    Loss = unrecoverable per-tenant DEKs. Rotation: shield's
#    `make rotate-kek-{dry,apply}` (in-place re-wrap, no downtime).
#
# 3. GATEWAY_ADMIN_KEY — X-Admin-Key for /v1/admin/* routes. Without
#    this set, the admin API refuses every request with 401. Operator
#    appends to THIS file (vibe-shield.env) on first enable:
#      echo "GATEWAY_ADMIN_KEY=vs-admin-$(openssl rand -hex 16)" >> /opt/vibe/env/vibe-shield.env
#    The enable-app.sh merge step preserves it across re-renders.
#
# A future appliance update can wire the renderer to substitute
# VIBE_SHIELD_KEK and GATEWAY_ADMIN_KEY automatically (the manifest
# already specifies their sources). Until then, the operator action
# above is the documented bootstrap step.

# --- Compliance toggles ---------------------------------------------
# Anthropic Zero Data Retention. Requires the ZDR addendum signed on
# the Anthropic account; the header alone does NOT activate ZDR.
ZDR_ENABLED=false

# --- Quotas ----------------------------------------------------------
# Defaults for tenants without an explicit policy override. Tune via
# per-tenant policies in the admin UI.
RATE_LIMIT_PER_MINUTE=60
SPEND_CAP_MICRODOLLARS=500000000

# --- Periodic key re-probe ------------------------------------------
# Re-runs the Anthropic /v1/models probe every N ms. 0 disables.
# Failures log warn; the next /v1/messages call fails-closed via the
# existing 401/503 paths.
ANTHROPIC_REPROBE_INTERVAL_MS=900000

# --- Request limits + session lifecycle -----------------------------
MAX_REQUEST_BYTES=1048576
SESSION_TTL_MINUTES=60

# --- Logging --------------------------------------------------------
LOG_LEVEL=info
