# vibe-shield.env.tmpl — rendered to /opt/vibe/env/vibe-shield.env by
# lib/enable-app.sh. Read by vibe-shield-gateway only (the engine and
# admin images don't consume any of these).
#
# Three secrets here that MUST survive across re-renders (lib/enable-app.sh
# preserves them via the _extract_env_value pattern):
#
#   - VS_KEK              — AES-256-GCM key-encryption key. Rotating it
#                            without `make rotate-kek-apply` (Vibe-Shield
#                            CLI) leaves the encrypted vault unrecoverable.
#   - GATEWAY_ADMIN_KEY   — X-Admin-Key for the admin UI + /v1/admin/*.
#                            Rotating it invalidates active operator sessions.
#   - DATABASE_URL embedded password — rotating it breaks the per-app DB role.
#
# ANTHROPIC_API_KEY is intentionally NOT in this template — it's
# inherited from appliance.env via env_file precedence (apps/vibe-shield.yml
# loads shared.env → appliance.env → vibe-shield.env). One key, every
# Vibe app that uses Anthropic shares it. To override per-app, add
# `ANTHROPIC_API_KEY=sk-...` below.

NODE_ENV=production
HOST=0.0.0.0
PORT=8080

# --- Storage (per-app role on shared Postgres, isolated Redis index) --
DATABASE_URL=@DATABASE_URL@
REDIS_URL=@REDIS_URL@

# --- Engine (internal-only, reached over vibe_net) --------------------
ENGINE_URL=http://vibe-shield-engine:8000

# --- Crypto + admin auth (generated once, preserved across re-renders) -
# 32 raw bytes base64-encoded. Wraps the per-tenant DEKs that encrypt
# every vault row. NEVER rotate this directly — use Vibe-Shield's
# `make rotate-kek-apply` which re-wraps every existing DEK under the
# new key inside a transaction.
VS_KEK=@VS_KEK@

# 32 hex chars. Operator pastes this into the admin UI's login form
# (X-Admin-Key header). Retrieve via:
#     sudo grep ^GATEWAY_ADMIN_KEY= /opt/vibe/env/vibe-shield.env
# Rotating logs out every active admin session.
GATEWAY_ADMIN_KEY=@GATEWAY_ADMIN_KEY@

# --- Migration gating -------------------------------------------------
# true → gateway entrypoint runs `node dist/migrate.js` before serving.
# update.sh sets this to false for the rollback-safety explicit-migrate
# path; first-enable lets the app self-migrate per the appliance convention.
MIGRATIONS_AUTO=true

# --- Admin SPA base path ----------------------------------------------
# Consumed by vibe-shield-admin's nginx entrypoint hook
# (/docker-entrypoint.d/40-base-path.sh) which sed-substitutes the
# /__VIBE_BASE_PATH__/ sentinel baked into the Vite bundle. Must match
# the Caddy path prefix exactly (/shield/ in LAN/Tailscale, /shield/
# under the single-host tunnel in domain mode). The renderer computes
# `/<slug-without-vibe-prefix>/` — same pattern as every other Vibe SPA.
VITE_BASE_PATH=@VITE_BASE_PATH@

# --- Operator-tunable knobs (commented = use gateway defaults) --------
# ZDR_ENABLED=false                      # Requires signed ZDR addendum with Anthropic.
# RATE_LIMIT_PER_MINUTE=60               # Per-(tenant, app) request cap. Per-tenant policy overrides.
# SPEND_CAP_MICRODOLLARS=500000000       # $500/mo default monthly cap (USD * 1e6).
# ANTHROPIC_REPROBE_INTERVAL_MS=900000   # 15 min Anthropic key re-probe. 0 disables.
# MAX_REQUEST_BYTES=1048576              # 1 MB. Anthropic accepts up to 256 KB on /v1/messages.
# SESSION_TTL_MINUTES=60                 # Vault DEK lifetime after last touch.
# LOG_LEVEL=info                         # fatal | error | warn | info | debug | trace | silent

# --- Operator override slot for ANTHROPIC_API_KEY ---------------------
# Uncomment to override appliance-wide value. Default is inherited from
# /opt/vibe/env/appliance.env (Settings → AI → Anthropic API key).
# ANTHROPIC_API_KEY=
