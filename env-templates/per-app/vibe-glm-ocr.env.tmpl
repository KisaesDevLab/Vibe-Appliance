# vibe-glm-ocr.env.tmpl — rendered to /opt/vibe/env/vibe-glm-ocr.env
# by lib/enable-app.sh. No DATABASE_URL — this app has no Postgres.

ALLOWED_ORIGIN=@ALLOWED_ORIGIN@
REDIS_URL=@REDIS_URL@

# The Ollama sidecar that ships with this app's overlay. Hostname
# resolves over vibe_net.
OLLAMA_URL=http://vibe-glm-ocr-ollama:11434

# --- Optional knobs (override via 'sudo nano /opt/vibe/env/vibe-glm-ocr.env') ---
# Vision-language model the OCR server should ask Ollama to use.
# OLLAMA_MODEL=llava:latest
