# vibe-payroll.env.tmpl — rendered to /opt/vibe/env/vibe-payroll.env
# by lib/enable-app.sh.

NODE_ENV=production

ALLOWED_ORIGIN=@ALLOWED_ORIGIN@
# Vibe-Payroll's backend reads CORS_ORIGIN, not ALLOWED_ORIGIN. Set both.
CORS_ORIGIN=@ALLOWED_ORIGIN@
DATABASE_URL=@DATABASE_URL@
REDIS_URL=@REDIS_URL@

# Vibe-Payroll's backend env validator requires SECRETS_ENCRYPTION_KEY
# (separate from ENCRYPTION_KEY despite the name). Mirror the shared
# encryption key under that alias so we don't generate a parallel
# secret the operator has to know about.
SECRETS_ENCRYPTION_KEY=@ENCRYPTION_KEY@

# The web image's /docker-entrypoint.d/40-base-path.sh sed-substitutes
# the SPA's `/__VIBE_BASE_PATH__/` sentinel with this value. Has to
# match the Caddy path prefix exactly (or the SPA's <script src>'s
# load from the wrong path and 404).
VITE_BASE_PATH=@VITE_BASE_PATH@

MIGRATIONS_AUTO=true

# --- Optional knobs ---
# (Vibe Payroll uses a state-tax-table provider that the operator can
# pin via STATE_TAX_PROVIDER once that PR lands upstream.)
