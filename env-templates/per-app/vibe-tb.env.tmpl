# vibe-tb.env.tmpl — rendered to /opt/vibe/env/vibe-tb.env by
# lib/enable-app.sh.
#
# Vibe-TB's knexfile reads INDIVIDUAL DB_* env vars rather than
# DATABASE_URL — so the appliance ships both styles. NODE_ENV must
# be `production` or knex falls into dev defaults (and the
# DB_PASSWORD-required guard short-circuits).

NODE_ENV=production

# --- Routing identity -------------------------------------------------
ALLOWED_ORIGIN=@ALLOWED_ORIGIN@
APP_BASE_URL=@ALLOWED_ORIGIN@

# --- Database (per-app role on the shared Postgres) -------------------
# Vibe-TB reads these individually via knexfile.js.
DB_HOST=@DB_HOST@
DB_PORT=@DB_PORT@
DB_NAME=@DB_NAME@
DB_USER=@DB_USER@
DB_PASSWORD=@DB_PASSWORD@
# DATABASE_URL kept for any future Vibe-TB code path that wants it.
DATABASE_URL=@DATABASE_URL@

# --- Redis (per-app logical DB on the shared Redis) -------------------
REDIS_URL=@REDIS_URL@

# --- SPA base path ----------------------------------------------------
# Vite SPA base-path — must match the Caddy prefix (`/<slug>/` in
# LAN/Tailscale, `/` in domain mode). Without it the SPA's <script>
# src URLs resolve to `/assets/...` and Caddy 404s every browser
# request after the page loads.
VITE_BASE_PATH=@VITE_BASE_PATH@

# --- Migration gating -------------------------------------------------
# True so the app self-migrates on first boot. update.sh runs explicit
# migrations on the update path with rollback safety.
MIGRATIONS_AUTO=true

# --- Optional knobs (override via 'sudo nano /opt/vibe/env/vibe-tb.env') ---
# Image tag is provided to compose by lib/enable-app.sh's
# `export APP_TAG=...` before `docker compose pull/up` — matches the
# `${APP_TAG:-latest}` ref in apps/vibe-tb.yml. No env-file value
# needed.
# ANTHROPIC_API_KEY=
