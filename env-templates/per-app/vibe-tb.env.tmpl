# vibe-tb.env.tmpl — rendered to /opt/vibe/env/vibe-tb.env by
# lib/enable-app.sh from console/manifests/vibe-tb.json.
#
# Markers (filled at render time):
#   @ALLOWED_ORIGIN@   resolved subdomain URL (https://tb.<domain> or http://...)
#   @DATABASE_URL@     postgresql://<user>:<pwd>@postgres:5432/<db>
#   @REDIS_URL@        redis://:<pwd>@redis:6379/<db_index>
#   @VIBE_TB_TAG@      pinned image tag from state.apps.vibe-tb.image_server_tag
#
# Sensitive lines are mode 600. Don't commit this file (it's in .gitignore
# under /opt/vibe paths anyway).

# --- Routing identity -------------------------------------------------
ALLOWED_ORIGIN=@ALLOWED_ORIGIN@

# --- Database (per-app role on the shared Postgres) -------------------
DATABASE_URL=@DATABASE_URL@

# --- Redis (per-app logical DB on the shared Redis) -------------------
REDIS_URL=@REDIS_URL@

# --- Migration gating -------------------------------------------------
# Set to true so the app self-migrates on its first boot (idempotent
# for empty schemas). The appliance still runs explicit migrations on
# the UPDATE path (update.sh) — that's where the rollback safety net
# matters. First-enable doesn't have rollback, so a bad
# manifest.migrations.command would unrecoverably fail every install;
# trusting auto-migrate avoids that footgun.
MIGRATIONS_AUTO=true

# --- Image tag (consumed by apps/vibe-tb.yml's ${VIBE_TB_TAG}) --------
VIBE_TB_TAG=@VIBE_TB_TAG@

# --- Optional knobs (override via 'sudo nano /opt/vibe/env/vibe-tb.env') ---
# ANTHROPIC_API_KEY=
