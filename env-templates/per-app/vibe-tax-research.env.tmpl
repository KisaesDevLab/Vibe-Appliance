# vibe-tax-research.env.tmpl — rendered to
# /opt/vibe/env/vibe-tax-research.env by lib/enable-app.sh.

NODE_ENV=production

ALLOWED_ORIGIN=@ALLOWED_ORIGIN@
# Vibe-Tax-Research validates PUBLIC_BASE_URL as a URL; default is
# http://localhost:5173. Match the operator's actual entry URL.
PUBLIC_BASE_URL=@ALLOWED_ORIGIN@

DATABASE_URL=@DATABASE_URL@
REDIS_URL=@REDIS_URL@

# Vibe-Tax-Research's env validator requires:
#   - MASTER_KEY            (64-char hex; wraps stored secrets)
#   - JWT_REFRESH_SECRET    (≥32 chars; signs refresh tokens)
# Mirror our shared crypto material under those names so we don't
# generate a parallel set of secrets the operator must track.
MASTER_KEY=@ENCRYPTION_KEY@
JWT_REFRESH_SECRET=@JWT_SECRET@

# Vite SPA base-path — same as vibe-payroll/vibe-mybooks.
VITE_BASE_PATH=@VITE_BASE_PATH@

MIGRATIONS_AUTO=true

# --- Operator-supplied (set after enable; see admin Apps panel) ---
# Required for the chat tier. Without it, Tax Research will fail back
# to a "no LLM configured" error in the UI rather than crash on boot.
# ANTHROPIC_API_KEY=
