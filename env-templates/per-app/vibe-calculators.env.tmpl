# vibe-calculators.env.tmpl — rendered to /opt/vibe/env/vibe-calculators.env
# by lib/enable-app.sh.
#
# Vibe-Calculators reads DATABASE_URL + REDIS_URL directly (no per-component
# DB_* split like vibe-tb). Migrations are run explicitly by enable-app.sh
# via the manifest's migrations.command, so MIGRATIONS_AUTO=false here.

NODE_ENV=production

# --- Routing identity -------------------------------------------------
ALLOWED_ORIGIN=@ALLOWED_ORIGIN@

# Vite SPA base-path — must match the Caddy prefix (`/<slug>/` in
# LAN/Tailscale, `/` in domain mode). Without it the SPA's <script>
# src URLs resolve to `/assets/...` and Caddy 404s every browser
# request after the page loads.
VITE_BASE_PATH=@VITE_BASE_PATH@

# --- Data plane ------------------------------------------------------
DATABASE_URL=@DATABASE_URL@
REDIS_URL=@REDIS_URL@

# Slot allocation for the shared Redis: 0 tb, 1 mybooks, 2 calculators,
# 3 tax-research, 4 payroll, 5 glm-ocr, 6 tx-converter.
VIBE_REDIS_DB=2

# --- Migrations -------------------------------------------------------
# False because enable-app.sh runs the manifest's migrations.command
# explicitly with rollback safety. Only flip to true if you remove the
# explicit migrate step.
MIGRATIONS_AUTO=false

# --- Deploy mode ------------------------------------------------------
# Calculators' inner Caddy reads this to choose between LAN HTTP, ACME
# HTTPS, or Tailscale serve. The appliance terminates TLS at its own
# ingress Caddy regardless, so 'lan' (plain HTTP inside the docker
# network) is correct here in every appliance mode.
VIBE_DEPLOY_MODE=lan
VIBE_OFFLINE=false
LOG_LEVEL=info

# --- Email (Phase 22) — inherited from appliance ---------------------
# Calculators reads VIBE_EMAIL_PROVIDER + the SMTP/Postmark/EmailIt
# blocks from appliance.env, which the admin Settings page populates.
# No per-app overrides needed unless this firm's calculators app
# needs a different sender than the appliance default.

# --- Optional knobs (override via 'sudo nano /opt/vibe/env/vibe-calculators.env') ---
# ANTHROPIC_API_KEY=
# VIBE_KMS_KEY=
# VIBE_AFR_FEED_URL=
