# vibe-connect.env.tmpl — rendered to /opt/vibe/env/vibe-connect.env by
# lib/enable-app.sh. Connect server reads these via apps/server/src/env.ts;
# Connect client (nginx) reads BASE_PATH / SESSION_COOKIE_PATH / TLS_MODE
# via infra/docker/nginx/entrypoint.sh.

NODE_ENV=production

# --- Database (single shared DATABASE_URL — Connect uses Knex) --------
DATABASE_URL=@DATABASE_URL@

# --- Session (cookie-based, NOT JWT) ----------------------------------
# Reuse the shared JWT_SECRET as the session signing key — same
# cryptographic strength, one fewer secret the operator has to track.
SESSION_SECRET=@JWT_SECRET@
SESSION_SECURE=true

# --- Path-prefix routing ----------------------------------------------
# Connect's nginx (vibe-connect-client) entrypoint validates BASE_PATH
# strictly: must be `/` or `/<lowercase>` with optional trailing slash.
# The appliance computes VITE_BASE_PATH per-mode:
#   LAN/Tailscale: /<slug>/   (path-prefix routing)
#   Domain:        /          (per-app subdomain — root)
# SESSION_COOKIE_PATH must match so the session cookie is scoped to the
# app's URL prefix.
BASE_PATH=@VITE_BASE_PATH@
SESSION_COOKIE_PATH=@VITE_BASE_PATH@

# --- TLS handling -----------------------------------------------------
# Caddy terminates TLS upstream of Connect's nginx. The in-app ACME
# ticker (TLS_MODE=internal) is off; Connect's nginx serves plain HTTP
# on :80 for Caddy to reverse-proxy.
TLS_MODE=external

# --- Operator-supplied (override via 'sudo nano /opt/vibe/env/vibe-connect.env') ---
# OIDC_ISSUER_URL=
# POSTMARK_INBOUND_WEBHOOK_SECRET=
# POSTFIX_RAW_BRIDGE_SECRET=
# CLAMD_HOST=
# CLAMD_PORT=
