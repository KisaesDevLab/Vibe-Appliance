# vibe-mybooks.env.tmpl — rendered to /opt/vibe/env/vibe-mybooks.env
# by lib/enable-app.sh.

NODE_ENV=production

ALLOWED_ORIGIN=@ALLOWED_ORIGIN@
# Vibe-MyBooks's CORS validator forbids `*`; default fallback is
# http://localhost:5173 in dev. Set to the appliance's URL.
CORS_ORIGIN=@ALLOWED_ORIGIN@
DATABASE_URL=@DATABASE_URL@
REDIS_URL=@REDIS_URL@

# Vibe-MyBooks's env validator requires PLAID_ENCRYPTION_KEY (used by
# utils/encryption.ts to wrap Plaid, Stripe, OAuth refresh tokens, TFA
# secrets — anything stored encrypted). Mirror the shared
# ENCRYPTION_KEY under that alias so we don't generate a parallel
# secret the operator has to track.
PLAID_ENCRYPTION_KEY=@ENCRYPTION_KEY@

# Vite SPA base-path — see vibe-payroll.env.tmpl for the why. Must
# match the Caddy prefix (`/<slug>/` in LAN/Tailscale, `/` in domain
# mode).
VITE_BASE_PATH=@VITE_BASE_PATH@

# Appliance lets the app self-migrate on first boot; explicit
# migrations land on the update path (update.sh).
MIGRATIONS_AUTO=true

# --- Optional knobs ---
# Override via 'sudo nano /opt/vibe/env/vibe-mybooks.env'.
# ANTHROPIC_API_KEY=
