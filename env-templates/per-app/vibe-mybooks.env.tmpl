# vibe-mybooks.env.tmpl — rendered to /opt/vibe/env/vibe-mybooks.env
# by lib/enable-app.sh.

NODE_ENV=production

ALLOWED_ORIGIN=@ALLOWED_ORIGIN@
# Vibe-MyBooks's CORS validator forbids `*`; default fallback is
# http://localhost:5173 in dev. Set to the appliance's URL.
CORS_ORIGIN=@ALLOWED_ORIGIN@
DATABASE_URL=@DATABASE_URL@
REDIS_URL=@REDIS_URL@

# Vibe-MyBooks's env validator requires PLAID_ENCRYPTION_KEY (used by
# utils/encryption.ts to wrap Plaid, Stripe, OAuth refresh tokens, TFA
# secrets — anything stored encrypted). Mirror the shared
# ENCRYPTION_KEY under that alias so we don't generate a parallel
# secret the operator has to track.
PLAID_ENCRYPTION_KEY=@ENCRYPTION_KEY@

# Vite SPA base-path — see vibe-payroll.env.tmpl for the why. Must
# match the Caddy prefix (`/<slug>/` in LAN/Tailscale, `/` in domain
# mode).
VITE_BASE_PATH=@VITE_BASE_PATH@

# Appliance lets the app self-migrate on first boot; explicit
# migrations land on the update path (update.sh).
MIGRATIONS_AUTO=true

# Appliance deploys api+web only (apps/vibe-mybooks.yml), no separate
# worker service. The api's /health endpoint includes a `workers`
# sub-check (vibe-mybooks-compatibility-addendum §3.6) gated by
# EXPECT_WORKER. Default true assumes the worker container is also
# running; without it /health returns 503 because no worker
# heartbeat ever lands in Redis. Disable the gate so the appliance's
# api-only topology stays healthy. Operators who later wire up a
# worker container can flip this to true.
EXPECT_WORKER=false

# --- License gate ---
# Vibe-MyBooks's bootstrap exits fatally if neither LICENSE_TOKEN nor
# DISABLE_LICENSE_CHECK is set. The upstream's .appliance/manifest.json
# documents the appliance's intended default as
# `DISABLE_LICENSE_CHECK=1` ("Appliance ships with license check
# disabled until the operator pastes a key via the appliance admin
# console" — vibe-mybooks-compatibility-addendum §3.8).
# Operators with a paid license set LICENSE_TOKEN + LICENSE_PUBLIC_KEY
# below (and flip DISABLE_LICENSE_CHECK to 0). The token is an RS256
# JWT issued by licensing.kisaes.com; the public key is a PEM-format
# RSA key matching that issuer.
DISABLE_LICENSE_CHECK=1
# LICENSE_TOKEN=
# LICENSE_PUBLIC_KEY=

# --- Optional knobs ---
# Override via 'sudo nano /opt/vibe/env/vibe-mybooks.env'.
# ANTHROPIC_API_KEY=
